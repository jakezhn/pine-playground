//@version=5
indicator("Auto Key Support/Resistance Levels", shorttitle="Auto S/R", overlay=true, max_lines_count=500, max_labels_count=500)

// Input settings
lookback = input.int(20, "Lookback Period", minval=5, maxval=100, tooltip="Number of bars to look back for pivot detection")
min_touches = input.int(2, "Minimum Touches", minval=2, maxval=10, tooltip="Minimum number of times price must touch a level")
touch_threshold = input.float(0.5, "Touch Threshold %", minval=0.1, maxval=2.0, tooltip="Percentage threshold for considering a touch")
strength_filter = input.int(3, "Strength Filter", minval=1, maxval=10, tooltip="Minimum strength of pivot points")
max_levels = input.int(10, "Maximum Levels", minval=5, maxval=50, tooltip="Maximum number of levels to display")

// Appearance settings
support_color = input.color(color.new(color.green, 80), "Support Color")
resistance_color = input.color(color.new(color.red, 80), "Resistance Color")
line_width = input.int(2, "Line Width", minval=1, maxval=5)
show_labels = input.bool(true, "Show Labels")
extend_lines = input.string("Right", "Extend Lines", options=["None", "Left", "Right", "Both"])

// Variables for level tracking
var line[] support_lines = array.new<line>()
var line[] resistance_lines = array.new<line>()
var label[] level_labels = array.new<label>()
var float[] support_levels = array.new<float>()
var float[] resistance_levels = array.new<float>()
var int[] support_touches = array.new<int>()
var int[] resistance_touches = array.new<int>()

// Function to calculate pivot highs and lows
pivot_high = ta.pivothigh(high, strength_filter, strength_filter)
pivot_low = ta.pivotlow(low, strength_filter, strength_filter)

// Function to check if price is near a level
is_near_level(price, level, threshold) =>
    math.abs(price - level) / level * 100 <= threshold

// Function to count touches at a level
count_touches(level, is_support, bars_back) =>
    touches = 0
    for i = 1 to bars_back
        if is_support
            if is_near_level(low[i], level, touch_threshold) or is_near_level(high[i], level, touch_threshold)
                touches := touches + 1
        else
            if is_near_level(high[i], level, touch_threshold) or is_near_level(low[i], level, touch_threshold)
                touches := touches + 1
    touches

// Function to find bounces from a level
find_bounces(level, is_support, bars_back) =>
    bounces = 0
    for i = 2 to bars_back
        if is_support
            // Check for bullish bounce from support
            if low[i] <= level * (1 + touch_threshold/100) and low[i] >= level * (1 - touch_threshold/100)
                if close[i-1] > low[i] and close[i] > close[i-1]
                    bounces := bounces + 1
        else
            // Check for bearish bounce from resistance
            if high[i] >= level * (1 - touch_threshold/100) and high[i] <= level * (1 + touch_threshold/100)
                if close[i-1] < high[i] and close[i] < close[i-1]
                    bounces := bounces + 1
    bounces

// Function to calculate level strength
calc_level_strength(level, is_support) =>
    touches = count_touches(level, is_support, lookback * 2)
    bounces = find_bounces(level, is_support, lookback * 2)
    volume_strength = 0.0
    
    // Calculate volume-weighted strength
    for i = 1 to lookback
        if is_support and is_near_level(low[i], level, touch_threshold)
            volume_strength := volume_strength + volume[i]
        else if not is_support and is_near_level(high[i], level, touch_threshold)
            volume_strength := volume_strength + volume[i]
    
    // Normalize volume strength
    avg_volume = ta.sma(volume, 20)
    volume_multiplier = volume_strength / (avg_volume * lookback)
    
    strength = touches * 2 + bounces * 3 + volume_multiplier
    strength

// Function to clean old levels
clean_old_levels() =>
    // Remove lines that are too far from current price
    current_price = close
    price_range = ta.atr(20) * 10
    
    // Clean support levels
    for i = array.size(support_levels) - 1 to 0
        level = array.get(support_levels, i)
        if math.abs(current_price - level) > price_range
            line_to_remove = array.get(support_lines, i)
            line.delete(line_to_remove)
            array.remove(support_lines, i)
            array.remove(support_levels, i)
            array.remove(support_touches, i)
    
    // Clean resistance levels
    for i = array.size(resistance_levels) - 1 to 0
        level = array.get(resistance_levels, i)
        if math.abs(current_price - level) > price_range
            line_to_remove = array.get(resistance_lines, i)
            line.delete(line_to_remove)
            array.remove(resistance_lines, i)
            array.remove(resistance_levels, i)
            array.remove(resistance_touches, i)

// Function to add or update level
add_or_update_level(level, is_support) =>
    found_existing = false
    
    if is_support
        for i = 0 to array.size(support_levels) - 1
            existing_level = array.get(support_levels, i)
            if is_near_level(level, existing_level, touch_threshold)
                // Update existing level
                touches = array.get(support_touches, i) + 1
                array.set(support_touches, i, touches)
                found_existing := true
                break
        
        if not found_existing and array.size(support_levels) < max_levels
            // Add new support level
            strength = calc_level_strength(level, true)
            if strength >= min_touches
                extend_type = extend_lines == "Left" ? extend.left : extend_lines == "Right" ? extend.right : extend_lines == "Both" ? extend.both : extend.none
                new_line = line.new(bar_index - lookback, level, bar_index, level, 
                                  color=support_color, width=line_width, extend=extend_type)
                array.push(support_lines, new_line)
                array.push(support_levels, level)
                array.push(support_touches, int(strength))
                
                if show_labels
                    label_text = "S: " + str.tostring(level, "#.##") + " (" + str.tostring(int(strength)) + ")"
                    new_label = label.new(bar_index, level, label_text, 
                                        color=color.new(color.green, 70), textcolor=color.white, 
                                        style=label.style_label_up, size=size.small)
                    array.push(level_labels, new_label)
    else
        for i = 0 to array.size(resistance_levels) - 1
            existing_level = array.get(resistance_levels, i)
            if is_near_level(level, existing_level, touch_threshold)
                // Update existing level
                touches = array.get(resistance_touches, i) + 1
                array.set(resistance_touches, i, touches)
                found_existing := true
                break
        
        if not found_existing and array.size(resistance_levels) < max_levels
            // Add new resistance level
            strength = calc_level_strength(level, false)
            if strength >= min_touches
                extend_type = extend_lines == "Left" ? extend.left : extend_lines == "Right" ? extend.right : extend_lines == "Both" ? extend.both : extend.none
                new_line = line.new(bar_index - lookback, level, bar_index, level, 
                                  color=resistance_color, width=line_width, extend=extend_type)
                array.push(resistance_lines, new_line)
                array.push(resistance_levels, level)
                array.push(resistance_touches, int(strength))
                
                if show_labels
                    label_text = "R: " + str.tostring(level, "#.##") + " (" + str.tostring(int(strength)) + ")"
                    new_label = label.new(bar_index, level, label_text, 
                                        color=color.new(color.red, 70), textcolor=color.white, 
                                        style=label.style_label_down, size=size.small)
                    array.push(level_labels, new_label)

// Main logic
if barstate.isconfirmed
    // Clean old levels periodically
    if bar_index % 10 == 0
        clean_old_levels()
    
    // Check for new pivot highs (potential resistance)
    if not na(pivot_high)
        add_or_update_level(pivot_high, false)
    
    // Check for new pivot lows (potential support)
    if not na(pivot_low)
        add_or_update_level(pivot_low, true)
    
    // Additional level detection based on round numbers for crypto
    current_price = close
    
    // Check for psychological levels (round numbers)
    psychological_levels = array.new<float>()
    
    // For BTC-like prices, find significant round numbers
    if current_price > 1000
        step = current_price > 10000 ? 1000 : 500
        base = math.floor(current_price / step) * step
        for i = -2 to 2
            level = base + i * step
            if level > 0
                array.push(psychological_levels, level)
    else if current_price > 100
        step = 50
        base = math.floor(current_price / step) * step
        for i = -2 to 2
            level = base + i * step
            if level > 0
                array.push(psychological_levels, level)
    else
        step = current_price > 10 ? 5 : 1
        base = math.floor(current_price / step) * step
        for i = -2 to 2
            level = base + i * step
            if level > 0
                array.push(psychological_levels, level)
    
    // Check psychological levels for touches
    for i = 0 to array.size(psychological_levels) - 1
        level = array.get(psychological_levels, i)
        touches = count_touches(level, true, lookback) + count_touches(level, false, lookback)
        if touches >= min_touches
            if level < current_price
                add_or_update_level(level, true)  // Support
            else
                add_or_update_level(level, false) // Resistance

// Alert conditions
alertcondition(not na(pivot_high), title="New Resistance Level", message="New resistance level detected at {{close}}")
alertcondition(not na(pivot_low), title="New Support Level", message="New support level detected at {{close}}")

// Price touch alerts
support_touch = false
resistance_touch = false

for i = 0 to array.size(support_levels) - 1
    level = array.get(support_levels, i)
    if is_near_level(low, level, touch_threshold)
        support_touch := true

for i = 0 to array.size(resistance_levels) - 1
    level = array.get(resistance_levels, i)
    if is_near_level(high, level, touch_threshold)
        resistance_touch := true

alertcondition(support_touch, title="Support Level Touch", message="Price touched support level")
alertcondition(resistance_touch, title="Resistance Level Touch", message="Price touched resistance level")

// Plot current price for reference
plot(close, title="Current Price", color=color.blue, linewidth=1, display=display.none)
